<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Select Your Seats" android:textSize="18sp"
        android:textStyle="bold" android:gravity="center" android:padding="8dp"/>

    <!-- Legend -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:padding="8dp">
        <View android:layout_width="20dp" android:layout_height="20dp"
            android:background="#4CAF50" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Available " android:layout_marginEnd="12dp"/>
        <View android:layout_width="20dp" android:layout_height="20dp"
            android:background="#F44336" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Booked " android:layout_marginEnd="12dp"/>
        <View android:layout_width="20dp" android:layout_height="20dp"
            android:background="#2196F3" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Selected"/>
    </LinearLayout>

    <!-- Seat Grid -->
    <GridView android:id="@+id/seatGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="6"
        android:horizontalSpacing="6dp"
        android:verticalSpacing="6dp"
        android:padding="8dp"/>

    <!-- Summary Bar -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EEEEEE"
        android:padding="12dp">

        <TextView android:id="@+id/tvSummary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="0 seats selected • Total: ৳0"/>

        <Button android:id="@+id/btnConfirm"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Confirm Booking" android:layout_marginTop="8dp"/>
    </LinearLayout>
</LinearLayout>